{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Valorant Tracker",
  "version": "0.3.23",
  "identifier": "com.xnooztv.val-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Valorant Tracker",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://media.valorant-api.com data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'none'",
      "devCsp": "default-src 'self'; img-src 'self' https://media.valorant-api.com data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420; object-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": "3FBF44427F5A7F15E239C975B608B7FBE676761D",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": {
        "cmd": "C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.26100.0\\x64\\signtool.exe",
        "args": ["sign", "/sha1", "3FBF44427F5A7F15E239C975B608B7FBE676761D", "/tr", "http://timestamp.digicert.com", "/td", "sha256", "/fd", "sha256", "%1"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0MDg3MkY1QzM3N0M5RUQKUldUdHlYZkQ5WElJcEJQblNVSW5tM3NGWjJCbFc5aGs1NmtBdnh4aUo5eEJva2VVd2RsMTlRNncK",
      "endpoints": [
        "https://github.com/xnooztvFR/val-tracker/releases/latest/download/latest.json"
      ]
    }
  }
}
