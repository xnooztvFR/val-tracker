{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Valorant Tracker",
  "version": "0.1.0",
  "identifier": "com.mri-bot.val-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Valorant Tracker",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": "EB04564FD14749DCF7D1CEAD1854CD4552E25727",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGREM2NTE0MzdENDk0RDMKUldUVGxOUTNGR1hjYjVXaEkyUldDckViL2hJTDcxLzlNSmJiWi91QXdqQUp6MUdTa2ZyQ0NUckEK",
      "endpoints": [
        "https://github.com/xnooztvFR/val-tracker/releases/latest/download/latest.json"
      ]
    }
  }
}
