{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Capacités de la fenêtre principale (titlebar custom : drag/minimize/close/mode mini, updater, clipboard, autostart) — scopée à `main` uniquement, distincte de `overlay.json` qui n'a besoin que d'un sous-ensemble minimal.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-always-on-top",
    "core:window:allow-outer-size",
    "core:window:allow-scale-factor",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-write-text",
    "autostart:default",
    "core:app:allow-version"
  ]
}
